<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smallcase API Suite" preserve-order="true">
<listeners>
    <listener class-name="resource.resource.CommonListener"/>
</listeners>

<test name="Test Runner for Trending API">
    <parameter name="Flow" value="Get Trending Assets"/>
    <classes>
        <class name="com.multiassetsearch.TrendingAPI"/>
    </classes>
</test>

<test name="Test Runner for Search Asset API">
    <parameter name="Flow" value="Search Assets"/>
    <classes>
        <class name="com.multiassetsearch.SearchAPI"/>
    </classes>
</test>

<test name="Test Runner for MultiAsset Stock Discovery" preserve-order="true">
    <parameter name="Flow" value="Search Config and Stock Discovery"/>
    <classes>
        <class name="com.multiassetsearch.StockConfigAPI"/>
        <class name="com.multiassetsearch.StockDiscoverAPI"/>
        <class name="com.multiassetsearch.StockIncludeExclude"/>
    </classes>
</test>

<test name="Test Runner for MultiAsset MF Discovery" preserve-order="true">
    <parameter name="Flow" value="Search Config and MF Discovery"/>
    <classes>
        <class name="com.multiassetsearch.MFConfigAPI"/>
        <class name="com.multiassetsearch.MFDiscoverAPI"/>
        <class name="com.multiassetsearch.MFIncludeExclude"/>
    </classes>
</test>

<test name="Test Runner for MultiAsset SC Discovery" preserve-order="true">
    <parameter name="Flow" value="Search Config and SC Discovery"/>
    <classes>
        <class name="com.multiassetsearch.SCConfigAPI"/>
        <class name="com.multiassetsearch.SCDiscoverAPI"/>
        <class name="com.multiassetsearch.SCIncludeExclude"/>
    </classes>
</test>

</suite>