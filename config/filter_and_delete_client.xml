<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="otp service suite">
    <listeners>
        <listener class-name="resource.resource.ListenerClass"/>
    </listeners>

    <test name="Test Runner for Filter and Delete Client API">
        <!-- The clientId value can be either 'email-login' or 'smallcase-platform' -->
        <parameter name="clientId" value="email-login" />
        <parameter name="Flow" value="Filter and Delete Client Check" />
        <classes>
            <class name="com.otpservice.FilterClient" />
            <class name="com.otpservice.DeleteFilteredClients" />
        </classes>
    </test>
</suite>