<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="MF Experience" preserve-order="true">

    <listeners>
        <listener class-name="resource.resource.CommonListener"/>
    </listeners>

    <test name="Sam login for MF Experience APIs" preserve-order="true">
        <parameter name="PhoneNo" value="9816805868"/>
        <parameter name="isInternalParam" value="false"/>
        <parameter name="Flow" value="Sam login for MF Experience APIs"/>
        <classes>
            <class name="com.smallcaseapi.samflow.SamLogin"/>
        </classes>
    </test>

    <test name="MF Experience Flows" preserve-order="true">
        <parameter name="PhoneNo" value="9816805868"/>
        <parameter name="Flow" value="MF Experience Flows"/>
        <classes>
            <class name="com.mutualfund.experience.DiscoverMFSearchTest"/>
            <class name="com.mutualfund.experience.DiscoverMFPeersTest"/>
            <class name="com.mutualfund.experience.DiscoverMFByMFIdTest"/>
            <class name="com.mutualfund.experience.DiscoverMFManagersByFMCodesTest"/>
            <class name="com.mutualfund.experience.SearchApiMutualFundsTest"/>
            <class name="com.mutualfund.experience.DiscoverMFByAMCCodeTest"/>
        </classes>
    </test>

</suite>


