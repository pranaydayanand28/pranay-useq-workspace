<!--        <classes>-->
<!--            <class name="com.smallcaseapi.SmallcaseProfileAPI">-->
<!--                <methods>-->
<!--                    <include name="brokerSmallcaseLoginView" />-->
<!--                </methods>-->
<!--            </class>-->
<!--        </classes>-->
<!--    </test>-->

    <!-- Test for Smallcase Profile API (Logout View) -->
    <test name="Test Runner for Smallcase Profile API Logout view">
        <parameter name="Flow" value="Smallcase/Broker Platform - Logout View" />

        <classes>
            <class name="com.smallcaseapi.SmallcaseProfileAPI">
                <methods>
                    <include name="samSmallcaseLogoutView" />
                    <include name="brokerSmallcaseLogoutView" />
                </methods>
            </class>
        </classes>
    </test>

</suite>