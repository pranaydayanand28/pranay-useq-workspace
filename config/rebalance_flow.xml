<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Rebalance API Suite">

    <listeners>
        <listener class-name="resource.resource.ListenerClass"/>
    </listeners>

    <!-- 1. Broker Auth -->
    <test name="01-Broker Auth Initialization">
        <parameter name="broker" value="kite"/>
        <parameter name="brokerLeprechaun" value="kite-leprechaun"/>
        <parameter name="brokerParam" value="someParamValue"/>
        <parameter name="app" value="platform"/>
        <classes>
            <class name="com.smallcaseapi.brokerAuthCookies.BrokerAuthCookies">
                <methods>
                    <include name="loginAndFetchRequestToken"/>
                </methods>
            </class>
        </classes>
    </test>


    <!-- 2. Login JWT -->
    <test name="02-Login With Valid JWT and Request Token">
        <parameter name="broker" value="kite"/>
        <classes>
            <class name="com.smallcaseapi.SmallcaseLoginAPI">
                <methods>
                    <include name="loginWithValidJWTAndRequestToken"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- 3. Buy flow -->
    <test name="03-Test Runner for Buy flow">
        <parameter name="broker" value="kite"/>
        <classes>
            <class name="com.smallcaseapi.orderFlow.BuySmallcaseAPI">
                <methods>
                    <include name="buySmallcaseAPI"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- 4. Manage flow -->
    <test name="04-Test Runner for Manage flow">
        <parameter name="broker" value="kite"/>
        <classes>
            <class name="com.smallcaseapi.orderFlow.ManageOrder">
                <methods>
                    <include name="manageOrder"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- 5. Push Rebalance -->
    <test name="05-Test Runner for Push Rebalance Flow">
        <parameter name="Flow" value="Push Rebalance"/>
        <classes>
            <class name="com.smallboard.PushRebalance">
                <methods>
                    <include name="pushRebalance"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- 6. Rebalance -->
    <test name="06-Test Runner for Rebalance Flow">
        <parameter name="Flow" value="Rebalance"/>
        <parameter name="broker" value="kite"/>
        <classes>
            <class name="com.smallcaseapi.orderFlow.RebalanceAPI">
                <methods>
                    <include name="rebalance"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>