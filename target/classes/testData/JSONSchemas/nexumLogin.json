{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "errors": {
      "type": "null"
    },
    "data": {
      "type": "object",
      "properties": {
        "lspJwt": {
          "type": "string"
        },
        "lspCsrf": {
          "type": "string"
        }
      },
      "required": [
        "lspJwt",
        "lspCsrf"
      ]
    }
  },
  "required": [
    "success",
    "errors",
    "data"
  ]
}